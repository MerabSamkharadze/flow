rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isProjectMember(projectId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds;
    }

    function isProjectAdmin(projectId) {
      return isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    function isProjectManagerOrAdmin(projectId) {
      let role = get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role;
      return isSignedIn() && (role == 'admin' || role == 'manager');
    }

    match /projects/{projectId} {
      allow read: if isProjectMember(projectId);
      allow create: if isSignedIn();
      allow update: if isProjectManagerOrAdmin(projectId);
      allow delete: if isProjectAdmin(projectId);

      match /members/{memberId} {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectManagerOrAdmin(projectId);
      }

      match /tasks/{taskId} {
        allow read: if isProjectMember(projectId);
        allow create: if isProjectManagerOrAdmin(projectId);
        allow update: if isProjectMember(projectId);
        allow delete: if isProjectManagerOrAdmin(projectId);

        match /subtasks/{subtaskId} {
          allow read, write: if isProjectMember(projectId);
        }

        match /comments/{commentId} {
          allow read: if isProjectMember(projectId);
          allow create: if isProjectMember(projectId);
          allow update, delete: if isSignedIn() && request.auth.uid == resource.data.authorId;
        }

        match /timeEntries/{entryId} {
          allow read: if isProjectMember(projectId);
          allow create: if isProjectMember(projectId);
          allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
        }
      }

      match /columns/{columnId} {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectManagerOrAdmin(projectId);
      }

      match /activity/{activityId} {
        allow read: if isProjectMember(projectId);
        allow create: if isProjectMember(projectId);
        allow update, delete: if false;
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /users/{userId}/notifications/{notifId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn();
      allow update, delete: if isOwner(userId);
    }

    match /users/{userId}/preferences/{prefDoc} {
      allow read, write: if isOwner(userId);
    }
  }
}
